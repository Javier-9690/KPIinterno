# Copia este archivo como .env y completa los valores

# Clave secreta para Flask sessions (cámbiala en producción)
SECRET_KEY=cambia-esta-clave-secreta-2025

# URL de base de datos (PostgreSQL en producción, SQLite local para desarrollo)
# Producción (Render / Railway):
# DATABASE_URL=postgresql://usuario:contraseña@host:5432/nombre_bd
# Local SQLite (sin configurar DATABASE_URL, se crea kpi.db automáticamente):
DATABASE_URL=
